{
	"name": "meta-fetcher",
	"description": "Simple metadata scraper for Node.js",
	"version": "3.1.1",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"files": [
		"dist"
	],
	"license": "MIT",
	"author": {
		"email": "rocktimthedev@gmail.com",
		"name": "Rocktim Saikia",
		"url": "https://rocktim.dev"
	},
	"funding": "https://github.com/sponsors/rocktimsaikia",
	"repository": "rocktimsaikia/meta-fetcher",
	"scripts": {
		"build": "tsup",
		"test": "pnpm build && ava",
		"release": "pnpm test && np --no-tests"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"cheerio": "1.0.0-rc.12"
	},
	"devDependencies": {
		"@rocktimsaikia/prettier-config": "^1.0.4",
		"@types/node": "^18.19.0",
		"ava": "^4.2.0",
		"tsup": "^5.12.4",
		"tsx": "^4.7.0",
		"typescript": "^4.6.3"
	},
	"np": {
		"contents": "dist"
	},
	"keywords": [
		"metadata",
		"scraper",
		"opengraph",
		"favicon",
		"meta-tags"
	],
	"prettier": "@rocktimsaikia/prettier-config",
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"format": [
			"cjs",
			"esm"
		],
		"minify": true,
		"clean": true,
		"dts": true
	}
}
